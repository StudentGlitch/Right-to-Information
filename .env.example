# Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# For production (Vercel), set these in the Vercel project dashboard under
# Settings → Environment Variables.
# Never commit .env or .env.local to version control.

# ──────────────────────────────────────────────────────────────────
# Next.js / Deployment
# ──────────────────────────────────────────────────────────────────

# Full public URL of your deployment, e.g. https://yourdomain.com
# Required in production. On Vercel, set this to your canonical URL.
# Omit (or leave unset) during local development — defaults to http://localhost:3000
NEXTAUTH_URL=https://your-domain.vercel.app

# Secret used by NextAuth to sign/encrypt JWTs and session cookies.
# Generate a strong random value: `openssl rand -base64 32`
# Required in production.
NEXTAUTH_SECRET=your-nextauth-secret

# ──────────────────────────────────────────────────────────────────
# Google OAuth (NextAuth provider)
# ──────────────────────────────────────────────────────────────────

# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ──────────────────────────────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas recommended for production).
# Example: mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/right_to_information
MONGODB_URI=mongodb://localhost:27017

# ──────────────────────────────────────────────────────────────────
# Midtrans (payment gateway)
# ──────────────────────────────────────────────────────────────────

# Set to "true" for live payments, "false" (or omit) for sandbox/testing.
MIDTRANS_IS_PRODUCTION=false

# Server & client keys from your Midtrans dashboard (https://dashboard.midtrans.com)
MIDTRANS_SERVER_KEY=SB-Mid-server-your-server-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-client-key
